# Copie para .env na pasta front (ou use este arquivo como referência).
#
# Dev (npm run dev):
#   VITE_API_URL vazio → base URL = http://<hostname>:8080
#   Ou: VITE_API_URL=http://127.0.0.1:8080
#
# Produção (npm run build):
#   O Vite carrega .env.production com VITE_API_URL=https://api.sharkgestao.com
#   Na Vercel você pode definir a mesma variável no painel.

VITE_API_URL=
