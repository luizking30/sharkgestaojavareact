# Copie para back/.env: cp back/.env.example back/.env
# O docker-compose carrega back/.env no serviço api.

DB_URL=jdbc:mysql://shark-db:3306/shark?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USER=root
DB_PASSWORD=123456
MP_TOKEN=seu_token_mercado_pago
MAIL_USER=seu_email@gmail.com
MAIL_PASSWORD=sua_senha_de_app_gmail

EVOLUTION_ENABLED=false
EVOLUTION_BASE_URL=http://evolution-api:8080
EVOLUTION_INSTANCE=sua_instancia
EVOLUTION_API_KEY=sua_api_key_evolution

# Front na Vercel (exemplo):
# APP_FRONTEND_BASE_URL=https://seu-projeto.vercel.app
# APP_FRONTEND_LOGIN_URL=https://seu-projeto.vercel.app/login
APP_FRONTEND_BASE_URL=https://sharkgestao.com
APP_FRONTEND_LOGIN_URL=https://sharkgestao.com/login
