# Exemplo alinhado ao Docker Compose (servicos na rede interna).
DB_URL=jdbc:mysql://shark-db:3306/nome_do_banco?createDatabaseIfNotExist=true
DB_USER=seu_usuario_mysql
DB_PASSWORD=sua_senha_mysql
MP_TOKEN=seu_token_mercado_pago
MAIL_USER=seu_email@gmail.com
MAIL_PASSWORD=sua_senha_de_app_gmail
EVOLUTION_ENABLED=false
EVOLUTION_BASE_URL=http://evolution-api:8080
EVOLUTION_INSTANCE=sua_instancia
EVOLUTION_API_KEY=sua_api_key
# Opcional: prévia de link no WhatsApp (true pode deixar mensagem vazia em alguns aparelhos).
# EVOLUTION_LINK_PREVIEW=false
# Opcional: manter o 9 do celular BR no JID (se balão vazio com o formato padrão).
# EVOLUTION_BR_MOBILE_KEEP_9=false

# URLs publicas do front (e-mails e WhatsApp). Em producao omita para usar https://sharkgestao.com
# FRONTEND_BASE_URL=https://seu-dominio.com
# FRONTEND_LOGIN_URL=https://seu-dominio.com/login
