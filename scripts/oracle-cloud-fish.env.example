# Copie para scripts/oracle-cloud-fish.env e preencha OCI_SUBNET_ID e OCI_IMAGE_ID.
# Carregar:  set -a && source scripts/oracle-cloud-fish.env && set +a
# (oracle-cloud-fish.env está no .gitignore.)

# Root compartment = mesmo OCID do tenancy (ajuste se usar compartment filho).
export OCI_COMPARTMENT_ID=ocid1.tenancy.oc1..aaaaaaaa4ortqjktjtiyzpfx7srs7tbwfnr5q26fu5z6d2zsf5ms7caek7nq

# Subnet "subnet-20260406-1610" — use o OCID (Console: Networking → Virtual cloud networks → Subnets → copiar OCID).
# Com CLI (após ~/.oci/oci_api_key.pem existir): 
#   oci network subnet list --compartment-id "$OCI_COMPARTMENT_ID" --query "data[?\"display-name\"=='subnet-20260406-1610'].id" --raw-output
export OCI_SUBNET_ID=

# Imagem Ubuntu ARM para VM.Standard.A1.Flex:
#   ./scripts/oracle-cloud-print-ubuntu-image-id.sh
#   export OCI_IMAGE_ID="<valor impresso>"
export OCI_IMAGE_ID=
